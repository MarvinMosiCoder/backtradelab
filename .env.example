APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
SESSION_SECURE_COOKIE=true

# Public legal-page identity. Replace these before production launch.
LEGAL_OPERATOR_NAME=BacktradeLab
LEGAL_CONTACT_EMAIL=privacy@backtradelab.com
LEGAL_JURISDICTION="Republic of the Philippines"
LEGAL_EFFECTIVE_DATE="July 15, 2026"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

PAYMONGO_ENABLED=false
PAYMONGO_MODE=test
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_PAYMENT_METHODS=card,gcash
PAYMONGO_TEST_BYPASS_CAPABILITIES=false
PAYMONGO_LIVE_ENABLED=false
PAYMONGO_BASE_URL=https://api.paymongo.com/v1
PAYMONGO_SIGNATURE_TOLERANCE=300
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Keep TLS certificate verification enabled outside local troubleshooting.
MARKET_HTTP_VERIFY=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net
POSTMARK_TOKEN=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# Optional Apple API integration. Keep certificate/key files outside source control.
APPLE_API_BASE_URL=
APPLE_API_BULK_ENROLL_ENDPOINT=
APPLE_API_SHOW_ORDER_DETAILS_ENDPOINT=
APPLE_API_CHECK_TRANSACTION_STATUS_ENDPOINT=
APPLE_API_CERTIFICATE_PATH=
APPLE_API_CERTIFICATE_KEY_PATH=
APPLE_API_SHIP_TO=
APPLE_API_TIMEZONE=420
APPLE_API_LANGUAGE=en
